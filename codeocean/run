#!/usr/bin/env bash
set -e

# ACHR.cu — Generate warmup points for metabolic network sampling
# Uses GLPK (open-source LP solver) + MPI

# Install build dependencies (in case postInstall wasn't run)
if ! command -v make &>/dev/null; then
    apt-get update -qq
    apt-get install -y --no-install-recommends \
        build-essential make gcc libglpk-dev openmpi-bin libopenmpi-dev
fi

# Parameters
N_WARMUP=2120

# Build VFWarmup with GLPK
cd /code/VFWarmup
make clean || true
GLPKDIR=/usr make glpk

# Code Ocean /data/ is read-only; copy MPS to writable /tmp/
MODEL_SRC=/data/models/P_Putida.mps
MODEL=/tmp/P_Putida.mps
cp "$MODEL_SRC" "$MODEL"

echo "=== Generating warmup points ==="
mpirun --allow-run-as-root -np 1 --bind-to none ./createWarmupPtsGLPK "$MODEL" $N_WARMUP

# Warmup CSV is written next to the MPS file: /tmp/P_Putida<nPts>warmup.csv
WARMUP_CSV=$(ls -t /tmp/*warmup.csv 2>/dev/null | head -1)
echo "Warmup CSV: $WARMUP_CSV"

# Validate output
NROWS=$(wc -l < "$WARMUP_CSV")
NCOLS=$(head -1 "$WARMUP_CSV" | tr ',' '\n' | wc -l)
echo "Output: ${NROWS} reactions x ${NCOLS} warmup points"

# Copy to results
cp "$WARMUP_CSV" /results/
echo ""
echo "=== Results ==="
ls -la /results/
echo "Done."
